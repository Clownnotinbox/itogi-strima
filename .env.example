# Local server
KRYL_PORT=8001

# Speech recognition
KRYL_WHISPER_MODEL=large-v3
KRYL_WHISPER_DEVICE=auto
KRYL_LANGUAGE=ru

# Ollama
KRYL_OLLAMA_URL=http://localhost:11434
KRYL_OLLAMA_MODEL=gemma4:12b

# Live updates
KRYL_LIVE_SUMMARY_SECONDS=7200
KRYL_LIVE_RECONNECT_GRACE_SECONDS=900

# GitHub Pages
KRYL_PAGES_AUTO_PUSH=0
KRYL_PAGES_REPO_URL=
KRYL_PAGES_BRANCH=main
